# MyServerMC Environment Variables
# Скопируйте этот файл в .env и настройте значения

# ============================================
# ИНТЕГРАЦИЯ С MYMCWEB
# ============================================
# Этот проект использует Caddy из репозитория web-template для HTTPS
# Убедитесь что:
# 1. Репозиторий web-template развернут
# 2. Caddy в web-template запущен
# 3. Сеть web_ssl создана
# 4. В web-template/Caddyfile добавлен конфиг для mc.example.com

# === PostgreSQL Database ===
POSTGRES_DB=minecraft_server
POSTGRES_USER=mcserver
POSTGRES_PASSWORD=CHANGEME

# === Backend API ===
JWT_SECRET=CHANGEME
NODE_ENV=production

# === YooKassa Configuration ===
YOOKASSA_SHOP_ID=your_shop_id_from_yookassa
YOOKASSA_SECRET_KEY=your_secret_key_from_yookassa

# ВАЖНО: Измените на реальный домен после его покупки!
# Примеры: https://example.com, https://example.com
YOOKASSA_RETURN_URL=https://example.com/payment/success
YOOKASSA_WEBHOOK_URL=https://example.com/api/payment/webhook

# === RCON Configuration ===
RCON_PASSWORD=CHANGEME

# === Minecraft Servers Memory (для itzg/minecraft-server) ===
SURVIVAL_MEMORY=10G
AI_RESEARCH_MEMORY=10G
LOBBY_MEMORY=2G
VELOCITY_MEMORY=1G
SURVIVALPLUS_MEMORY=12G

# === Frontend Configuration ===
# Для локальной разработки: http://localhost
# Для production с доменом: https://mc.example.com
FRONTEND_URL=http://localhost

# API URL для frontend (относительный путь работает через Caddy)
VITE_API_URL=/api

# === Timezone ===
TZ=Europe/Moscow

# === Production настройки (после настройки web-template) ===
# Раскомментируйте после настройки web-template Caddy:
#
# FRONTEND_URL=https://mc.example.com
# YOOKASSA_RETURN_URL=https://mc.example.com/payment/success
# YOOKASSA_WEBHOOK_URL=https://mc.example.com/api/payment/webhook
# NODE_ENV=production
